<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ShapeAppearance.DOG.SmallComponent" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.DOG.MediumComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.DOG.LargeComponent" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <!-- Outlined card style (minimalist, no shadow, subtle border) -->
    <style name="Widget.DOG.CardView.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardBackgroundColor">?attr/colorSurfaceContainerLow</item>
        <item name="strokeColor">?attr/colorOutlineVariant</item>
        <item name="strokeWidth">@dimen/card_stroke</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="shapeAppearance">?attr/shapeAppearanceMediumComponent</item>
        <item name="contentPadding">@dimen/space_md</item>
    </style>

    <!-- Toolbar style: flat surface -->
    <style name="Widget.DOG.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">?attr/colorSurface</item>
        <item name="titleTextAppearance">?attr/textAppearanceTitleLarge</item>
        <item name="subtitleTextAppearance">?attr/textAppearanceBodyMedium</item>
    </style>

    <!-- MaterialAlertDialog overlay: rounded corners, themed surface -->
    <style name="ThemeOverlay.DOG.MaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="shapeAppearance">@style/ShapeAppearance.DOG.LargeComponent</item>
        <item name="shapeAppearanceOverlay">@null</item>
        <item name="dialogCornerRadius">24dp</item>
        <item name="colorSurface">?attr/colorSurfaceContainerHigh</item>
        <item name="android:colorBackground">?attr/colorSurfaceContainerHigh</item>
        <item name="materialAlertDialogTitleTextStyle">@style/TextAppearance.DOG.AlertTitle</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.DOG.Button.Dialog</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.DOG.Button.Dialog</item>
        <item name="buttonBarNeutralButtonStyle">@style/Widget.DOG.Button.Dialog</item>
    </style>

    <style name="TextAppearance.DOG.AlertTitle" parent="MaterialAlertDialog.Material3.Title.Text">
        <item name="android:textAppearance">?attr/textAppearanceHeadlineSmall</item>
    </style>

    <style name="Widget.DOG.Button.Dialog" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">?attr/colorPrimary</item>
    </style>

    <!-- NavigationView item shape (rounded selected pill) -->
    <style name="ShapeAppearance.DOG.NavItem" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">28dp</item>
    </style>

    <!-- Tab text appearances -->
    <style name="TextAppearance.DOG.Tab" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textStyle">normal</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="TextAppearance.DOG.Tab.Selected" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>
